<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <?ifndef ProductVersion ?>
    <?define ProductVersion = "0.1.0" ?>
  <?endif?>

  <?ifndef UpgradeCode ?>
    <?define UpgradeCode = "B8A2AE7B-41E3-4E64-9A5F-41E1D1D6C6F8" ?>
  <?endif?>

  <?ifndef DistDir ?>
    <?error DistDir no fue definido. Pasa -d DistDir="...\dist" desde build_msi.ps1 ?>
  <?endif?>

  <Package
      Name="AymaraLang"
      Manufacturer="AymaraLang Project"
      Version="$(var.ProductVersion)"
      UpgradeCode="$(var.UpgradeCode)"
      Language="1033"
      InstallerVersion="500"
      Compressed="yes"
      Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="Ya existe una versión más reciente de AymaraLang." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(sys.SOURCEFILEDIR)..\..\assets\logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)..\EULA.rtf" />

    <ui:WixUI Id="WixUI_FeatureTree" InstallDirectory="INSTALLDIR" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <Feature Id="CoreFeature" Title="Core" Level="1">
      <ComponentGroupRef Id="CoreRootFiles" />
      <ComponentGroupRef Id="CoreBinFiles" />
      <ComponentGroupRef Id="CoreShareFiles" />
      <ComponentGroupRef Id="CoreToolchainFiles" />
      <ComponentRef Id="PathEnv" />
      <ComponentRef Id="AymFileAssoc" />
    </Feature>

  </Package>

  <Fragment>
    <WixVariable Id="WixUIInstallDir" Value="INSTALLDIR" />
  </Fragment>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="AymaraLang">
        <Directory Id="BINDIR" Name="bin" />
        <Directory Id="SHAREDIR" Name="share" />
        <Directory Id="TOOLCHAINDIR" Name="toolchain" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="CoreRootFiles" Directory="INSTALLDIR" Source="$(var.DistDir)">
      <Files Include="README.md" />
      <Files Include="LICENSE" />
      <Files Include="EULA.txt" />
    </ComponentGroup>

    <ComponentGroup Id="CoreBinFiles" Directory="BINDIR" Source="$(var.DistDir)\bin">
      <Files Include="**\*" />
    </ComponentGroup>

    <ComponentGroup Id="CoreShareFiles" Directory="SHAREDIR" Source="$(var.DistDir)\share">
      <Files Include="**\*" />
    </ComponentGroup>

    <ComponentGroup Id="CoreToolchainFiles" Directory="TOOLCHAINDIR" Source="$(var.DistDir)\toolchain">
      <Files Include="**\*" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="PathEnv" Directory="INSTALLDIR" Guid="D3D1F4E4-9E39-4E0B-A6C1-0E5D8A6A3C11">
      <RegistryValue Root="HKLM"
                     Key="Software\AymaraLang"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />

      <Environment Id="AymaraLangPath"
                   Name="PATH"
                   Value="[BINDIR]"
                   Part="last"
                   System="yes"
                   Action="set" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="AymFileAssoc" Directory="INSTALLDIR" Guid="47191562-61EC-452C-B15C-F27DC513ED76">
      <File Id="AymLogoIco" Source="$(sys.SOURCEFILEDIR)..\..\assets\logo.ico" KeyPath="yes" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\.aym"
                     Type="string"
                     Value="AymaraLang.Source" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\AymaraLang.Source"
                     Type="string"
                     Value="AymaraLang Source File" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\AymaraLang.Source\DefaultIcon"
                     Type="string"
                     Value="[INSTALLDIR]logo.ico,0" />
      <RegistryValue Root="HKLM"
                     Key="Software\Classes\AymaraLang.Source\shell\open\command"
                     Type="string"
                     Value="&quot;[BINDIR]aymc.exe&quot; &quot;%1&quot;" />
    </Component>
  </Fragment>

</Wix>
